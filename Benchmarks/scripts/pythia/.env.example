# scripts/pythia/.env — Machine-specific configuration for the Pythia cluster.
# Copy to .env and fill in your values. .env is gitignored.

# SSH alias/host for the Pythia login nodes (configure in ~/.ssh/config).
PYTHIA_HOST="pythia"

# Your home directory on Pythia (NFS — code landing zone only, keep tiny).
PYTHIA_HOME="/home/youruser"

# Your username on bll01 (the data-source machine that submits sweeps).
BLL01_USER="youruser"

# bll01 IP, reachable from Pythia compute nodes (for data/results staging).
BLL01_IP="10.0.0.1"

# Absolute path to this Benchmarks/ repo on bll01.
BLL01_REPO_DIR="/path/to/divergence-decoding-inference-time-unlearning/Benchmarks"

# Durable store on bll01 for trained model weights (HF-upload artifacts).
# /hpc_temp is wiped after 14 days, so training weights are rsynced here.
CHECKPOINT_DIR="/data/lab/dd-unlearning-checkpoints"

# HuggingFace token for gated models (Llama-2 / Llama-3).
HF_TOKEN="hf_xxx"
